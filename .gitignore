!.vscode/launch.json
.eclipse/
*.classpath
*.project
*.settings/

# OS files
.DS_Store
Thumbs.db

# JPackage / native build output
*.exe
*.msi
*.dmg
*.pkg
*.deb
*.rpm

# Log files
*.log
logs/
